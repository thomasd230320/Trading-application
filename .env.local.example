# Copy this file to .env.local and fill in your values.
# Also add these to your Vercel project settings under Environment Variables.

# ─── Supabase (auth + signal history) ────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Public (browser-safe) — used by the auth client and any RLS-scoped reads
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private (server-only) — service role for inserting into signal_history
# from the API routes. NEVER expose this to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Whop subscription gate (optional) ───────────────────────────────────────
# If WHOP_API_KEY is unset, the auth gate falls back to Supabase-only — every
# verified Supabase email can sign in. Set it to require an active Whop
# membership on the email used to log in.
# Find these in: Whop Dashboard → Developer → API Keys

WHOP_API_KEY=
# Optional — scopes the membership check to a single product / access pass.
# If unset, ANY active Whop membership on the email is accepted.
WHOP_PRODUCT_ID=
# Optional — set to "1" to surface the internal Whop API result inline on
# the login page, so you can debug rejected sign-ins. Turn off in normal
# operation (it can leak product / plan IDs to the user).
WHOP_DEBUG=
